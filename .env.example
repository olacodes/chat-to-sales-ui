# ChatToSales UI — Environment Variables
# Copy to .env.local and fill in real values.

# Backend REST API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Backend WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Tenant identifier passed to the WebSocket URL: /ws/{tenant_id}
NEXT_PUBLIC_TENANT_ID=default

# ── Meta WhatsApp Embedded Signup ─────────────────────────────────────────────
# Required for the real WhatsApp onboarding flow.
# Find these in your Meta App Dashboard → WhatsApp → Embedded Signup Builder.

# Your Meta App ID (visible at the top of the App Dashboard)
NEXT_PUBLIC_META_APP_ID=

# Facebook Login for Business configuration ID
# Create one at App Dashboard → Facebook Login for Business → Configurations
NEXT_PUBLIC_META_CONFIG_ID=

# Graph API version to target (keep at latest stable)
NEXT_PUBLIC_META_GRAPH_VERSION=v25.0
